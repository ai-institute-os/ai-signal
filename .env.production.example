# AISignal — Production Environment Variables
# Copy this file to .env and fill in all values before deploying.
# Variables marked OBLIGATORISK must be set — the app will fail or be insecure without them.

# ─── Database: Turso (libSQL) ─────────────────────────────────────────────────
# OBLIGATORISK — App will not start without a valid database connection.
# Create a database at https://turso.tech and copy the URL and auth token.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ─── Auth ────────────────────────────────────────────────────────────────────
# OBLIGATORISK — Used to sign and verify JWT session tokens. Min 32 characters.
# App throws at startup if unset.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Admin secret for the /api/admin endpoints and AIScore activation webhook.
# Must match AISIGNAL_ADMIN_SECRET in AIScore's .env.
ADMIN_SECRET=change-me-random-admin-secret

# ─── Cron ────────────────────────────────────────────────────────────────────
# OBLIGATORISK — Secret to protect cron job endpoints from unauthorized calls.
# Vercel injects this automatically as a Bearer token when using Vercel Cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me-generate-with-openssl-rand-hex-32

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_...

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Live secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret from Stripe dashboard → Webhooks → signing secret.
# Required to verify that payment webhooks genuinely come from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Public URL ──────────────────────────────────────────────────────────────
# OBLIGATORISK — Public base URL used in email links and redirects.
NEXT_PUBLIC_BASE_URL=https://aisignal.dk
