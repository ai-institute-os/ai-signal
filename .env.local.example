# Analytics — Plausible (domain, e.g. aisignal.dk) or GA4 (measurement ID, e.g. G-XXXXXXXXXX)
# Leave unset to disable analytics tracking.
NEXT_PUBLIC_ANALYTICS_ID=

# Required: at least one AI provider key
OPENAI_API_KEY=sk-...

# Optional: Google Gemini for multi-provider monitoring
GOOGLE_API_KEY=AIza...

# Optional: Perplexity for multi-provider monitoring
PERPLEXITY_API_KEY=pplx-...

# Optional: Email notifications via Resend (https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AISignal <alerts@aisignal.dk>

# Optional: Public base URL for email links
NEXT_PUBLIC_BASE_URL=https://aisignal.dk

# Optional: Secret to protect the cron endpoint
# Vercel injects this automatically when using Vercel Cron
CRON_SECRET=your-secret-here

# Optional: How many hours between scheduled monitoring runs (default: 24)
MONITOR_INTERVAL_HOURS=24

# Secret for the /api/admin/aiscore-activate endpoint (AII-221).
# Must match AISIGNAL_ADMIN_SECRET in AIScore's .env
ADMIN_SECRET=

# Stripe billing (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret (from Stripe dashboard → Webhooks)
# Listen for: customer.subscription.created, customer.subscription.updated,
#             customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring prices in Stripe dashboard (test mode)
# Mellem: 997 DKK/month recurring
STRIPE_PRICE_MELLEM=price_...
# Stor: 2497 DKK/month recurring
STRIPE_PRICE_STOR=price_...

# Database: Turso (libSQL) — REQUIRED
# The app will not start without TURSO_DATABASE_URL.
# Create a database at https://turso.tech and copy the URL and auth token.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# JWT signing secret — REQUIRED in production
# Used to sign and verify session tokens. MUST be set in production.
# The app falls back to a hardcoded dev secret if unset — never deploy without this.
# Generate with: openssl rand -hex 32
JWT_SECRET=generate-random-32+-char-secret-here
